# ===== Модуль мониторинга сервера (Amvera) =====
# Все переменные добавить в Amvera -> Переменные/Секреты окружения

# chat_id администратора/группы для алертов (число)
MONITOR_ADMIN_CHAT_ID=123456789

# Понятная метка сервера (попадает в текст алерта)
MONITOR_SERVER_NAME=prod-amvera

# Интервал сбора метрик, секунды
MONITOR_INTERVAL_SEC=60

# Сколько дней хранить историю метрик
MONITOR_RETENTION_DAYS=30

# --- Пороги алертов (в процентах) ---
MONITOR_CPU_THRESHOLD=90
MONITOR_MEM_THRESHOLD=85
MONITOR_DISK_THRESHOLD=90

# Путь к постоянному хранилищу Amvera (по умолчанию /data)
MONITOR_DISK_PATH=/data

# Кулдаун между однотипными алертами, секунды (чтобы не заспамить)
MONITOR_ALERT_COOLDOWN_SEC=300

# Собирать ли load average (в контейнере Amvera отражает хост!)
MONITOR_COLLECT_LOAD=true

# --- Безопасность HTTP API метрик ---
# Если задан — все /api/metrics/* требуют заголовок `X-Monitor-Token: <значение>`.
# Для публичного URL Amvera (https://<проект>.amvera.io) ОБЯЗАТЕЛЬНО задайте токен
# (случайная длинная строка), иначе метрики ресурсов будут доступны всем.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
# MONITOR_API_TOKEN=your-secret-token-here
